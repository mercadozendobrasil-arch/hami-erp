# Ant Design Pro / Umi dev proxy target for the NestJS API.
# The browser still calls /api/*; Umi proxies those requests to this origin in dev.
ERP_API_BASE_URL=http://localhost:3001
# ERP frontend role-specific tokens. In most deployments, choose one of these
# and copy it into UMI_APP_ERP_API_TOKEN for the active frontend surface.
UMI_APP_ERP_VIEWER_TOKEN=
UMI_APP_ERP_OPERATOR_TOKEN=
UMI_APP_ERP_ADMIN_TOKEN=

# Active token used by the current frontend deployment for /api/erp requests.
# Example:
# UMI_APP_ERP_API_TOKEN=${UMI_APP_ERP_VIEWER_TOKEN}
UMI_APP_ERP_API_TOKEN=
