NODE_ENV=development
APP_NAME=shopee-service
PORT=3001
API_PREFIX=api
SWAGGER_PATH=docs

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/shopee_service?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

POSTGRES_DB=shopee_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

QUEUE_PREFIX=shopee-service
LOG_LEVEL=debug

SHOPEE_ENV=sandbox
SHOPEE_SANDBOX_BASE_URL=https://partner.test-stable.shopeemobile.com
# Must be a uint32 integer string. Replace with the numeric partner_id from Shopee Open Platform.
SHOPEE_SANDBOX_PARTNER_ID=123456
SHOPEE_SANDBOX_PARTNER_KEY=replace_me
SHOPEE_SANDBOX_REDIRECT_URL=http://localhost:3000/shop/auth
SHOPEE_PROD_BASE_URL=https://partner.shopeemobile.com
# Must be a uint32 integer string. Replace with the numeric partner_id from Shopee Open Platform.
SHOPEE_PROD_PARTNER_ID=123456
SHOPEE_PROD_PARTNER_KEY=replace_me
SHOPEE_PROD_REDIRECT_URL=https://your-production-domain.com/shop/auth
SHOPEE_WEBHOOK_SECRET=
SHOPEE_TIMEOUT_MS=10000
SHOPEE_RETRY_MAX_ATTEMPTS=3
SHOPEE_RETRY_BASE_DELAY_MS=300
SHOPEE_RETRY_MAX_DELAY_MS=2000
SHOPEE_RATE_LIMIT_MIN_INTERVAL_MS=0

FOCUS_NFE_ENV=homologation
FOCUS_NFE_HOMOLOGATION_BASE_URL=https://homologacao.focusnfe.com.br
FOCUS_NFE_PROD_BASE_URL=https://api.focusnfe.com.br
FOCUS_NFE_TOKEN=replace_me

NUVEM_FISCAL_ENV=sandbox
NUVEM_FISCAL_SANDBOX_BASE_URL=https://api.sandbox.nuvemfiscal.com.br
NUVEM_FISCAL_PROD_BASE_URL=https://api.nuvemfiscal.com.br
NUVEM_FISCAL_AUTH_URL=https://auth.nuvemfiscal.com.br/oauth/token
NUVEM_FISCAL_CLIENT_ID=replace_me
NUVEM_FISCAL_CLIENT_SECRET=replace_me
NUVEM_FISCAL_SCOPES=empresa cep cnpj nfe nfce nfse
NUVEM_FISCAL_TIMEOUT_MS=10000
NUVEM_FISCAL_RETRY_MAX_ATTEMPTS=3
