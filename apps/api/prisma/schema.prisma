generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

enum ErpLabelStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  DOWNLOADED
}

enum ProductMediaType {
  IMAGE
  VIDEO
  ATTACHMENT
}

enum ProductMediaSourceType {
  ORIGINAL
  PRODUCT
  SKU
  AI
}

enum ProductAiTaskType {
  POSTER_BATCH
  MAIN_IMAGE_OPTIMIZE
  SCENE_IMAGE
  DETAIL_CONTENT_IMAGE
  FULL_EDIT
  PARTIAL_EDIT
}

enum ProductAiTaskStatus {
  CREATED
  QUEUED
  PROCESSING
  RENDERING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

enum ProductAiAssetType {
  POSTER
  MAIN_IMAGE
  SCENE_IMAGE
  DETAIL_IMAGE
}

enum ProductAiAssetAuditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductAiAssetPublishStatus {
  DRAFT
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum ProductAiAssetVersionType {
  INITIAL
  REGENERATE
  FULL_EDIT
  PARTIAL_EDIT
}

enum ProductMediaUsageType {
  PRODUCT_MAIN
  PRODUCT_DETAIL
  MARKETING_MATERIAL
  CHANNEL_PUBLISH
}

model ShopeeShop {
  id          String          @id @default(cuid())
  shopId      BigInt          @unique
  region      String?
  shopName    String?
  status      ShopStatus      @default(ACTIVE)
  tokens      ShopeeToken[]
  webhooks    WebhookEvent[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ShopeeToken {
  id                    String      @id @default(cuid())
  shop                  ShopeeShop  @relation(fields: [shopRef], references: [id], onDelete: Cascade)
  shopRef               String
  accessToken           String
  refreshToken          String
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([shopRef])
}

model JobRecord {
  id           String    @id @default(cuid())
  queueName    String
  jobName      String
  status       JobStatus @default(PENDING)
  payload      Json?
  result       Json?
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([queueName, status])
  @@index([jobName, status])
  @@index([createdAt])
}

model ErpOrderProjection {
  id                     String    @id @default(cuid())
  shopId                 String
  orderSn                String
  orderStatus            String
  fulfillmentStage       String
  packageNumber          String?
  packageStatus          String?
  logisticsStatus        String?
  shippingCarrier        String?
  shippingDocumentStatus String?
  shippingDocumentType   String?
  invoiceStatus          String?
  buyerUsername          String?
  totalAmount            Decimal?  @db.Decimal(18, 2)
  currency               String?
  remark                 String?
  locked                 Boolean   @default(false)
  auditStatus            String    @default("PENDING")
  warehouseName          String?
  logisticsChannel       String?
  tags                   Json?
  afterSaleStatus        String    @default("NONE")
  parentOrderSn          String?
  mergedIntoOrderSn      String?
  splitGroupId           String?
  createTime             DateTime?
  updateTime             DateTime?
  raw                    Json?
  lastSyncedAt           DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([shopId, orderSn])
  @@index([shopId, fulfillmentStage])
  @@index([shopId, orderStatus])
  @@index([shopId, shippingDocumentStatus])
  @@index([shopId, auditStatus])
  @@index([shopId, locked])
  @@index([shopId, afterSaleStatus])
  @@index([shopId, warehouseName])
  @@index([splitGroupId])
  @@index([updateTime])
}

model ErpOrderOperationLog {
  id           String   @id @default(cuid())
  shopId       String?
  orderSn      String?
  action       String
  status       String
  message      String?
  jobRecordId  String?
  request      Json?
  response     Json?
  errorMessage String?
  operatorId   String?
  createdAt    DateTime @default(now())

  @@index([shopId, orderSn])
  @@index([action, status])
  @@index([jobRecordId])
  @@index([createdAt])
}

model ErpShippingLabelRecord {
  id                   String         @id @default(cuid())
  shopId               String
  orderSn              String
  packageNumber        String?
  shippingDocumentType String?
  status               ErpLabelStatus @default(PENDING)
  jobRecordId          String?
  result               Json?
  errorMessage         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  downloadedAt         DateTime?

  @@index([shopId, orderSn])
  @@index([status])
  @@index([jobRecordId])
}

model WebhookEvent {
  id          String         @id @default(cuid())
  shop        ShopeeShop?    @relation(fields: [shopRef], references: [id], onDelete: SetNull)
  shopRef     String?
  topic       String
  eventId     String?        @unique
  payload     Json
  status      WebhookStatus  @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([shopRef, status])
}

model ProductMedia {
  id           String                 @id @default(cuid())
  tenantId     String
  productId    String
  mediaType    ProductMediaType
  sourceType   ProductMediaSourceType
  fileUrl      String
  thumbnailUrl String?
  fileName     String?
  sortNo       Int                    @default(0)
  isMain       Boolean                @default(false)
  status       String                 @default("enabled")
  createdBy    String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([tenantId, productId, sourceType])
  @@index([tenantId, productId, isMain])
}

model ProductAiTask {
  id                String              @id @default(cuid())
  tenantId          String
  taskNo            String              @unique
  productId         String
  taskType          ProductAiTaskType
  status            ProductAiTaskStatus @default(CREATED)
  progress          Int                 @default(0)
  sourceMediaIds    Json
  inputSnapshotJson Json
  promptText        String?
  totalCount        Int                 @default(0)
  successCount      Int                 @default(0)
  failCount         Int                 @default(0)
  errorMessage      String?
  createdBy         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  finishedAt        DateTime?
  assets            ProductAiAsset[]

  @@index([tenantId, productId, status])
  @@index([tenantId, taskType])
}

model ProductAiAsset {
  id               String                     @id @default(cuid())
  tenantId         String
  productId        String
  taskId           String
  task             ProductAiTask              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assetType        ProductAiAssetType
  assetName        String
  bizTag           String?
  currentVersionId String?
  auditStatus      ProductAiAssetAuditStatus  @default(PENDING)
  publishStatus    ProductAiAssetPublishStatus @default(DRAFT)
  createdBy        String
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  versions         ProductAiAssetVersion[]
  usages           ProductMediaUsage[]

  @@index([tenantId, productId, assetType])
  @@index([taskId])
}

model ProductAiAssetVersion {
  id              String                    @id @default(cuid())
  tenantId        String
  assetId         String
  asset           ProductAiAsset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  versionNo       Int
  parentVersionId String?
  versionType     ProductAiAssetVersionType
  editPrompt      String?
  fileUrl         String
  thumbnailUrl    String?
  width           Int?
  height          Int?
  fileSize        BigInt?
  isCurrent       Boolean                   @default(false)
  createdBy       String
  createdAt       DateTime                  @default(now())
  usages          ProductMediaUsage[]

  @@unique([assetId, versionNo])
  @@index([tenantId, assetId, isCurrent])
}

model ProductMediaUsage {
  id          String                @id @default(cuid())
  tenantId    String
  productId   String
  assetId     String
  asset       ProductAiAsset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  versionId   String
  version     ProductAiAssetVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  usageType   ProductMediaUsageType
  usageTarget String?
  sortNo      Int                    @default(0)
  status      String                 @default("active")
  createdBy   String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([tenantId, productId, usageType])
  @@index([assetId, versionId])
}
