NODE_ENV=development
APP_NAME=shopee-service
PORT=3001
API_PREFIX=api
SWAGGER_PATH=docs

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/shopee_service?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

POSTGRES_DB=shopee_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

QUEUE_PREFIX=shopee-service
LOG_LEVEL=debug

SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_BASE_URL=https://partner.shopeemobile.com
SHOPEE_WEBHOOK_SECRET=
SHOPEE_REDIRECT_URI=http://localhost:3000/api/auth/callback
SHOPEE_TIMEOUT_MS=10000
SHOPEE_RETRY_MAX_ATTEMPTS=3
SHOPEE_RETRY_BASE_DELAY_MS=300
SHOPEE_RETRY_MAX_DELAY_MS=2000
SHOPEE_RATE_LIMIT_MIN_INTERVAL_MS=0
