
# ERP API service port
PORT=3001

# PostgreSQL connection string used by Prisma and the NestJS service
DATABASE_URL="postgresql://postgres:Dong3285%40@127.0.0.1:5432/shopee_erp?schema=public"

# Frontend callback base URL
# Preferred key: FRONTEND_URL
# Backward-compatible alias supported by the validator: ERP_FRONTEND_URL
FRONTEND_URL="https://staging.hamimih.com"

# Shopee Open Platform app credentials
SHOPEE_PARTNER_ID="1232286"
SHOPEE_PARTNER_KEY="shpk4a7647566273576b53634872746853586c6a64735043645466617a636a48"
SHOPEE_REGION="TEST_GLOBAL"

# Shopee OAuth callback handled by server/erp-api
SHOPEE_REDIRECT_URL="https://staging.hamimih.com/api/shopee/auth/callback"

# Redis is optional in phase 1
REDIS_URL="redis://127.0.0.1:6379"
REDIS_PREFIX="shopee-erp-staging"

# Local initialization checklist:
# 1. Create a local .env from this file
# 2. Start PostgreSQL and create the target database
# 3. Run `npm run prisma:generate`
# 4. Run `npx prisma migrate dev`
# 5. Start the API with `npm run start:dev`
# 6. Check `GET /api/health` before opening the frontend pages
