{
  "name": "hami-erp",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",

    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build": "npm run build:api && npm run build:web",

    "lint:web": "npm --workspace apps/web run lint",
    "lint:api": "npm --workspace apps/api run lint",
    "lint": "npm run lint:api && npm run lint:web",

    "db:generate": "npm --workspace apps/api exec prisma generate",
    "db:migrate": "npm --workspace apps/api exec prisma migrate dev"
  }
}
